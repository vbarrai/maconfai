{
  "name": "maconfai",
  "version": "0.1.0",
  "description": "Minimal skills manager for Claude Code, Cursor, and Codex",
  "type": "module",
  "bin": {
    "maconfai": "./bin/cli.mjs"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "obuild",
    "dev": "node --experimental-strip-types src/cli.ts",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "knip": "knip",
    "lint": "oxlint src/",
    "prettier": "prettier --check .",
    "prettier:format": "prettier --write ."
  },
  "devDependencies": {
    "@clack/prompts": "^0.11.0",
    "@types/node": "^22.10.0",
    "gray-matter": "^4.0.3",
    "knip": "^5.86.0",
    "obuild": "^0.4.22",
    "oxlint": "^1.55.0",
    "picocolors": "^1.1.1",
    "prettier": "^3.8.1",
    "simple-git": "^3.27.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.17"
  },
  "author": "Vincent Barrault <vincentb45@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vbarrai/maconfai.git"
  },
  "keywords": [
    "claude-code",
    "cursor",
    "codex",
    "skills",
    "ai",
    "cli"
  ],
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.17.1"
}
